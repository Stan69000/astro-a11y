{
  "name": "astro-a11y-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "node --test tests/**/*.test.js",
    "lint": "node scripts/check-workspace.js && eslint packages/ tests/",
    "format": "prettier --write 'packages/**/*.js' 'tests/**/*.js' 'scripts/**/*.js'",
    "prepare": "husky",
    "example:scan": "node packages/cli/dist/bin.js check ./examples/static-site/dist --mode learning",
    "security:audit": "pnpm audit --prod"
  },
  "devDependencies": {
    "playwright": "^1.55.0",
    "eslint": "^10.2.1",
    "prettier": "^3.0.0",
    "husky": "^9.0.0"
  }
}
